BOT_TOKEN=your_bot_token_here
WEBHOOK_PORT=8080
# Нужен, если сервер не может стабильно достучаться до api.telegram.org (частая история для VPS в РФ)
# PROXY_URL=socks5://login:password@host:port

DIMAN_GOOGLE_CREDENTIALS_PATH=./credentials_diman.json
PARTNER_GOOGLE_CREDENTIALS_PATH=./credentials_partner.json

GEMINI_API_KEY=your_gemini_api_key
# ОБЯЗАТЕЛЬНО проверь актуальное имя модели в aistudio.google.com перед деплоем
GEMINI_MODEL=gemini-flash-latest

DIMAN_CHAT_ID=your_telegram_chat_id
DIMAN_SPREADSHEET_ID=your_google_sheet_id
DIMAN_SHORTCUT_TOKEN=придумай_длинный_случайный_токен

PARTNER_CHAT_ID=partner_telegram_chat_id
PARTNER_SPREADSHEET_ID=partner_google_sheet_id
PARTNER_SHORTCUT_TOKEN=придумай_другой_длинный_случайный_токен
